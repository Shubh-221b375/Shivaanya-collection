# Razorpay — storefront (safe in browser)
# 1) https://dashboard.razorpay.com → Account & Settings → API Keys
# 2) Copy Key Id (rzp_test_… or rzp_live_…). Never put Key Secret in VITE_*.
VITE_RAZORPAY_KEY_ID=

# Razorpay — server only (Vercel → Project → Settings → Environment Variables)
# Required for “Pay online”: creates Order so Checkout shows exact cart total.
# Do NOT commit real values. Local: use `vercel dev` from this folder or test on a Preview deploy.
# RAZORPAY_KEY_SECRET=
# Optional; defaults to VITE_RAZORPAY_KEY_ID if unset:
# RAZORPAY_KEY_ID=

# Optional: public URL of your S3/CloudFront bucket (no trailing slash). Objects must be at .../media/...
# VITE_MEDIA_BASE_URL=https://your-distribution.cloudfront.net
# VITE_MEDIA_BASE_URL=https://shivaanya-collection-media.s3.ap-south-1.amazonaws.com
VITE_MEDIA_BASE_URL=
