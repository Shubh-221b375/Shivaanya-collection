# Razorpay Checkout (amount auto-filled from cart)
# 1) Sign in: https://dashboard.razorpay.com
# 2) Go to: Account & Settings → API Keys → Generate Key (test or live)
# 3) Copy the "Key Id" (starts with rzp_test_ or rzp_live_) — NOT the Key Secret
# 4) Rename this file to .env.local and paste your key, then restart: npm run dev
VITE_RAZORPAY_KEY_ID=

# Optional: public URL of your S3/CloudFront bucket (no trailing slash). Objects must be at .../media/...
# VITE_MEDIA_BASE_URL=https://your-distribution.cloudfront.net
# VITE_MEDIA_BASE_URL=https://shivaanya-collection-media.s3.ap-south-1.amazonaws.com
VITE_MEDIA_BASE_URL=
